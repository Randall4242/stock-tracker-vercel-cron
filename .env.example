# Vercel project env vars (在 Vercel Dashboard → Settings → Environment Variables 设置)
# 不要 commit 真实值到 git

# GitHub Personal Access Token (PAT)
# 1. 访问 https://github.com/settings/tokens?type=beta
# 2. 生成 fine-grained token，Repository access 选 Randall4242/mavis-output
# 3. Permissions → Repository permissions → Actions 勾 "Read and write"
# 4. 复制生成的 token (只显示一次)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Vercel cron 鉴权用（防止别人误调 API）
# 任意 32+ 字符的随机字符串，例如：openssl rand -hex 32
CRON_SECRET=your_random_secret_here_at_least_32_chars
